function renderBracket(){
  const grid=document.getElementById('bracketGrid');
  if(!grid)return;
  grid.innerHTML=NCAA_BRACKET_2025.regions.map(r=>{
    return '<div class="bracket-region"><h4><i class="fas fa-trophy" style="color:#00a86b"></i> '+r.name+'</h4>'+
      r.teams.map(t=>{
        const cls=t.seed<=4?' style="color:#00a86b;font-weight:600"':'';
        return '<div class="bracket-team"'+cls+'><span><span class="seed-num">#'+t.seed+'</span>'+t.name+'</span>'+
          (t.record?'<span style="font-size:10px;color:var(--nb-muted)">'+t.record+'</span>':'')+'</div>';
      }).join('')+'</div>';
  }).join('');
}

