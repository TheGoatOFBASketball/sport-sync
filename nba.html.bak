<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>NBA Games — Live NBA Scores | NBA.com</title>
<meta name="description" content="Complete NBA coverage — Live scores, standings, player stats, contracts, salary cap, free agents, March Madness, and Draft."/>
<meta name="theme-color" content="#051c2d"/>
<link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>🏀</text></svg>"/>
<link rel="stylesheet" href="index.css"/>
<script src="espn-api.js" defer></script>

<script src="players-data.js" defer></script>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
<link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700;900&family=Roboto+Condensed:wght@400;600;700;800&family=Roboto+Slab:wght@400;700&display=swap" rel="stylesheet"/>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"/>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{--nb-red:#c8102e;--nb-orange:#ff6b00;--nb-gold:#ffd700;--nb-blue:#1d428a;--nb-navy:#051c2d;--nb-bg:#f0f2f5;--nb-card:#fff;--nb-card2:#fafbfc;--nb-border:#e0e4ea;--nb-border2:#d0d6df;--nb-text:#1a1a2e;--nb-muted:#6b7a8f;--nb-topbar-h:46px;--nb-subnav-h:40px;--nb-shadow:0 2px 8px rgba(0,0,0,0.08);--nb-glow:rgba(200,16,46,0.15)}
[data-theme="dark"]{--nb-bg:#0d1117;--nb-card:#161b22;--nb-card2:#1c2333;--nb-border:#30363d;--nb-border2:#21262d;--nb-text:#e6edf3;--nb-muted:#8b949e;--nb-shadow:0 2px 8px rgba(0,0,0,0.3);--nb-glow:rgba(200,16,46,0.25)}
[data-theme="dark"] .nba-subnav{background:var(--nb-card)}
[data-theme="dark"] .nba-leftnav{background:var(--nb-card)}
[data-theme="dark"] .sc-card-header{background:linear-gradient(135deg,var(--nb-card2),var(--nb-card))}
[data-theme="dark"] .team-logo-sm{background:var(--nb-card2)}
[data-theme="dark"] .filter-btn,.scoreboard-nav-btn,.sds-scroll-btn,.egc-tv,.egc-logo,.egc-network-pill,.egc-leader-avatar{background:var(--nb-card2)}
[data-theme="dark"] .filter-btn:hover,.scoreboard-nav-btn:hover,.sds-scroll-btn:hover{background:var(--nb-border);color:var(--nb-text)}
[data-theme="dark"] .scoreboard-date-strip{background:var(--nb-card2)}
[data-theme="dark"] .score-date-chip:hover{background:var(--nb-card2)}
[data-theme="dark"] .espn-game-card.is-live{background:linear-gradient(135deg,var(--nb-card),rgba(200,16,46,0.08))}
[data-theme="dark"] .standings-header,.conf-divider td{background:var(--nb-card2)}
[data-theme="dark"] .standings-conf-header{background:linear-gradient(135deg,var(--nb-card2),var(--nb-card))}
[data-theme="dark"] .espn-standings-table th{background:linear-gradient(135deg,var(--nb-card2),var(--nb-card))}
[data-theme="dark"] .playoff-badge.e{background:var(--nb-border);color:var(--nb-muted)}
[data-theme="dark"] .player-avatar,.news-img{background:linear-gradient(135deg,var(--nb-card2),var(--nb-border))}
[data-theme="dark"] .sc-select{background:var(--nb-card2);color:var(--nb-text);border-color:var(--nb-border)}
[data-theme="dark"] .standings-decade-btn{background:var(--nb-card2);color:var(--nb-muted);border-color:var(--nb-border)}
[data-theme="dark"] .standings-decade-btn:hover{color:var(--nb-text);border-color:var(--nb-red)}
[data-theme="dark"] .standings-decade-btn.active{color:#fff;background:var(--nb-red);border-color:var(--nb-red)}
[data-theme="dark"] .leftnav-item:hover{background:rgba(200,16,46,0.1)}
[data-theme="dark"] .leftnav-item.active{background:rgba(200,16,46,0.15)}
body{background:var(--nb-bg);color:var(--nb-text);font-family:"Roboto",-apple-system,sans-serif;font-size:13px;line-height:1.4;min-height:100vh;-webkit-font-smoothing:antialiased}
a{color:inherit;text-decoration:none}
button{cursor:pointer;border:none;background:none;font-family:inherit;color:inherit}

/* TOPBAR */
.nba-topbar{position:sticky;top:0;z-index:200;height:var(--nb-topbar-h);background:linear-gradient(90deg,#051c2d 0%,#0d2b4a 100%);display:flex;align-items:center;padding:0 14px;gap:10px;box-shadow:0 2px 12px rgba(5,28,45,0.3)}
.nba-topbar .back-link{display:flex;align-items:center;gap:5px;font-size:12px;font-weight:500;color:rgba(255,255,255,0.5);transition:color .15s}
.nba-topbar .back-link:hover{color:#fff}
.nba-topbar .divider{width:1px;height:18px;background:rgba(255,255,255,0.12)}
.nba-topbar .league-badge{background:linear-gradient(135deg,#c8102e,#ff4500);color:#fff;font-size:10px;font-weight:800;letter-spacing:1px;padding:2px 9px;border-radius:3px;text-transform:uppercase;box-shadow:0 1px 4px rgba(200,16,46,0.3)}
.nba-topbar .page-title{font-family:"Roboto Condensed",sans-serif;font-size:16px;font-weight:700;color:#fff;letter-spacing:.3px}
.nba-topbar .live-pill{display:flex;align-items:center;gap:4px;background:linear-gradient(135deg,#c8102e,#ff4500);color:#fff;font-size:10px;font-weight:700;padding:2px 8px;border-radius:3px;box-shadow:0 1px 4px rgba(200,16,46,0.3)}
.nba-topbar .live-pill .dot{width:5px;height:5px;border-radius:50%;background:#fff;animation:blink 1s infinite}
@keyframes blink{0%,100%{opacity:1}50%{opacity:0.2}}
.nba-topbar .spacer{flex:1}
.nba-topbar .topbar-links{display:flex;gap:6px}
.nba-topbar .topbar-link{font-size:11px;font-weight:600;color:rgba(255,255,255,0.5);padding:4px 10px;border-radius:5px;border:1px solid rgba(255,255,255,0.1);transition:all .15s}
.nba-topbar .topbar-link:hover{color:#fff;border-color:rgba(255,255,255,0.25);background:rgba(255,255,255,0.06)}

/* HERO */
.nba-hero{background:linear-gradient(135deg,#051c2d 0%,#0d2b4a 40%,#1d428a 100%);padding:20px 24px 18px;position:relative;overflow:hidden}
.nba-hero::before{content:"";position:absolute;inset:0;background:radial-gradient(circle at 15% 50%,rgba(255,107,0,0.08) 0%,transparent 50%),radial-gradient(circle at 85% 30%,rgba(200,16,46,0.1) 0%,transparent 50%),radial-gradient(circle at 50% 80%,rgba(255,215,0,0.04) 0%,transparent 40%);pointer-events:none}
.nba-hero-inner{max-width:1200px;margin:0 auto;position:relative;z-index:1}
.nba-hero-top{display:flex;align-items:center;justify-content:space-between;gap:16px;flex-wrap:wrap}
.nba-hero-text h1{font-family:"Roboto Condensed",sans-serif;font-size:1.8rem;font-weight:800;color:#fff;letter-spacing:-.5px;line-height:1;margin-bottom:3px}
.nba-hero-text h1 em{background:linear-gradient(135deg,#ff6b00,#ffd700);-webkit-background-clip:text;-webkit-text-fill-color:transparent;font-style:normal}
.nba-hero-text p{color:rgba(255,255,255,0.55);font-size:12px}
.nba-hero-text p a{color:#ffd700;font-weight:600}
.nba-hero-text p a:hover{text-decoration:underline}
.hero-cap-row{display:flex;flex-wrap:wrap;border:1px solid rgba(255,255,255,0.1);border-radius:6px;overflow:hidden}
.hero-cap-stat{padding:7px 14px;border-right:1px solid rgba(255,255,255,0.1);min-width:90px}
.hero-cap-stat:last-child{border-right:none}
.hero-cap-label{font-size:8px;font-weight:700;letter-spacing:1.2px;text-transform:uppercase;color:rgba(255,255,255,0.4);margin-bottom:2px}
.hero-cap-value{font-family:"Roboto Condensed",sans-serif;font-size:15px;font-weight:700;color:#fff;line-height:1}
.hero-cap-value.orange{color:#ff8c00}
.hero-cap-value.green{color:#00e676}
.hero-cap-value.gold{color:#ffd740}

/* SUBNAV */
.nba-subnav{background:#fff;border-bottom:1px solid var(--nb-border);position:sticky;top:var(--nb-topbar-h);z-index:190;display:flex;overflow-x:auto;box-shadow:0 1px 4px rgba(0,0,0,0.04)}
.nba-subnav::-webkit-scrollbar{display:none}
.nba-tab{padding:0 16px;height:var(--nb-subnav-h);display:flex;align-items:center;gap:5px;font-size:12px;font-weight:600;color:var(--nb-muted);border-bottom:2px solid transparent;cursor:pointer;white-space:nowrap;transition:all .15s}
.nba-tab i{font-size:11px}
.nba-tab:hover{color:var(--nb-text)}
.nba-tab.active{color:var(--nb-red);border-bottom-color:var(--nb-red)}
.nba-tab .tab-badge{font-size:8px;font-weight:800;background:var(--nb-red);color:#fff;padding:1px 5px;border-radius:3px;letter-spacing:.5px}

/* BODY LAYOUT */
.nba-body{display:grid;grid-template-columns:190px 1fr;max-width:1300px;margin:0 auto;min-height:calc(100vh - var(--nb-topbar-h) - var(--nb-subnav-h))}
@media(max-width:1000px){.nba-body{grid-template-columns:1fr}}

/* LEFTNAV */
.nba-leftnav{background:#fff;border-right:1px solid var(--nb-border);padding:14px 0;position:sticky;top:calc(var(--nb-topbar-h) + var(--nb-subnav-h));height:calc(100vh - var(--nb-topbar-h) - var(--nb-subnav-h));overflow-y:auto}
@media(max-width:1000px){.nba-leftnav{display:none}}
.leftnav-group{margin-bottom:16px}
.leftnav-group-label{font-size:8px;font-weight:800;letter-spacing:1.8px;text-transform:uppercase;color:var(--nb-muted);padding:0 14px;margin-bottom:3px}
.leftnav-item{display:flex;align-items:center;gap:7px;padding:7px 14px;font-size:12px;font-weight:500;color:var(--nb-muted);cursor:pointer;transition:all .12s;border-left:3px solid transparent}
.leftnav-item i{font-size:11px;width:13px;text-align:center}
.leftnav-item:hover{background:rgba(200,16,46,0.04);color:var(--nb-text)}
.leftnav-item.active{color:var(--nb-red);border-left-color:var(--nb-red);background:rgba(200,16,46,0.06);font-weight:700}
.leftnav-rule{font-size:10px;color:var(--nb-muted);padding:4px 14px 4px 34px}

/* CONTENT AREA */
.nba-content{padding:16px;display:flex;flex-direction:column;gap:16px}
.nba-panel{display:none;flex-direction:column;gap:16px}
.nba-panel.active{display:flex}

/* SC-CARD */
.sc-card{background:var(--nb-card);border:1px solid var(--nb-border);border-radius:8px;overflow:hidden;box-shadow:var(--nb-shadow);transition:box-shadow .15s}
.sc-card:hover{box-shadow:0 4px 14px rgba(0,0,0,0.1)}
.sc-card-header{display:flex;align-items:center;justify-content:space-between;padding:10px 14px;background:linear-gradient(135deg,#f8f9fb,#fff);border-bottom:1px solid var(--nb-border);flex-wrap:wrap;gap:6px}
.sc-card-title{font-family:"Roboto Condensed",sans-serif;font-size:13px;font-weight:700;color:var(--nb-text);display:flex;align-items:center;gap:6px}
.sc-card-title i{color:var(--nb-red)}
.sc-card-meta{font-size:10px;color:var(--nb-muted)}
.game-list{padding:8px;display:flex;flex-direction:column;gap:6px}
.team-logo-sm{width:30px;height:30px;border-radius:50%;background:#f0f2f5;display:flex;align-items:center;justify-content:center;font-size:8px;font-weight:700;overflow:hidden;flex-shrink:0}
.team-logo-sm img{width:100%;height:100%;object-fit:contain}

/* SCORES TWO-COL */
.scores-two-col{display:grid;grid-template-columns:1fr 300px;gap:16px;align-items:start}
@media(max-width:1100px){.scores-two-col{grid-template-columns:1fr}}

/* FILTER BAR */
.filter-bar{display:flex;gap:5px;padding:9px 14px;overflow-x:auto;border-bottom:1px solid var(--nb-border2)}
.filter-bar::-webkit-scrollbar{display:none}
.filter-btn{padding:5px 12px;border-radius:5px;font-size:11px;font-weight:600;color:var(--nb-muted);background:#f0f2f5;border:1px solid var(--nb-border);white-space:nowrap;transition:.15s}
.filter-btn:hover{color:var(--nb-text);background:#e4e7ec}
.filter-btn.active{background:var(--nb-red);color:#fff;border-color:var(--nb-red);box-shadow:0 1px 6px rgba(200,16,46,0.25)}
.live-badge-sm{display:inline-flex;align-items:center;gap:3px;background:rgba(200,16,46,0.1);color:var(--nb-red);padding:2px 6px;border-radius:3px;font-size:9px;font-weight:700}
.live-badge-sm .dot{width:4px;height:4px;border-radius:50%;background:var(--nb-red);animation:blink 1s infinite}

/* SCOREBOARD NAV */
.scoreboard-nav-btn{width:24px;height:24px;border-radius:4px;background:#f0f2f5;border:1px solid var(--nb-border);color:var(--nb-text);font-size:10px;display:flex;align-items:center;justify-content:center;cursor:pointer;transition:all .12s}
.scoreboard-nav-btn:hover{background:#e4e7ec;color:var(--nb-text)}

/* SCHEDULE SIDEBAR */
.sch-date-group{border-bottom:1px solid var(--nb-border2)}
.sch-date-group:last-child{border-bottom:none}
.sch-date-header{padding:8px 14px 4px;font-size:10px;font-weight:700;color:var(--nb-red);text-transform:uppercase;letter-spacing:.4px}
.sch-game{display:flex;align-items:center;justify-content:space-between;padding:5px 14px 5px 20px;transition:background .15s}
.sch-game:hover{background:rgba(200,16,46,0.03)}
.sch-no-games{color:var(--nb-muted);font-size:11px;justify-content:center;padding:6px}
.sch-matchup{display:flex;align-items:center;gap:6px}
.sch-team{display:flex;align-items:center;gap:4px;font-size:12px;font-weight:600;color:var(--nb-text)}
.sch-vs{color:var(--nb-muted);font-size:10px}
.sch-score{font-size:12px;font-weight:700;color:var(--nb-text);min-width:22px;text-align:right}
.sch-score.live{color:#c8102e}
.sch-live{color:#c8102e;font-size:9px;font-weight:700}
.sch-meta{font-size:10px;color:var(--nb-muted);white-space:nowrap}

/* DATE STRIP */
.sds-wrap{position:relative;display:flex;align-items:stretch}
.sds-scroll-btn{flex-shrink:0;width:22px;border:none;background:#f0f2f5;color:var(--nb-muted);cursor:pointer;font-size:10px;display:flex;align-items:center;justify-content:center;transition:background .12s,color .12s;border-bottom:1px solid var(--nb-border2)}
.sds-scroll-btn:hover{background:#e4e7ec;color:var(--nb-text)}
.scoreboard-date-strip{display:flex;overflow-x:auto;gap:3px;padding:6px 10px;border-bottom:1px solid var(--nb-border2);background:#f8f9fb;scroll-behavior:smooth}
.scoreboard-date-strip::-webkit-scrollbar{display:none}
.score-date-chip{flex-shrink:0;padding:3px 9px;border-radius:4px;font-size:10px;font-weight:600;color:var(--nb-muted);background:var(--nb-card);border:1px solid var(--nb-border);cursor:pointer;transition:all .12s;text-align:center;min-width:42px}
.score-date-chip:hover{color:var(--nb-text);background:#f0f2f5}
.score-date-chip.active{background:linear-gradient(135deg,var(--nb-red),#ff4500);border-color:var(--nb-red);color:#fff;box-shadow:0 1px 6px rgba(200,16,46,0.2)}
.score-date-chip .chip-day{font-size:8px;display:block;letter-spacing:.4px;text-transform:uppercase}
.score-date-chip .chip-date{font-size:12px;font-weight:700;display:block}
.score-date-spacer{flex-shrink:0;width:1px;background:var(--nb-border2);margin:2px 4px;align-self:stretch}
.score-date-label{flex-shrink:0;font-size:9px;font-weight:700;color:var(--nb-muted);padding:3px 6px 3px 3px;display:flex;align-items:center;letter-spacing:.2px;text-transform:uppercase}

/* GAME CARDS */
.espn-scoreboard-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(270px,1fr));gap:10px}
.espn-game-card{background:var(--nb-card);border:1px solid var(--nb-border);border-radius:8px;padding:12px 14px;cursor:pointer;transition:all .15s;position:relative;box-shadow:var(--nb-shadow)}
.espn-game-card:hover{box-shadow:0 6px 20px rgba(0,0,0,0.12);border-color:#c8102e;transform:translateY(-2px)}
.espn-game-card.is-live{border-left:3px solid var(--nb-red);background:linear-gradient(135deg,#fff,#fff5f5)}
.espn-game-card.is-final{opacity:.85}
.egc-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:8px}
.egc-status{font-size:9px;font-weight:700;color:var(--nb-muted);text-transform:uppercase;letter-spacing:.6px}
.egc-status.live{color:var(--nb-red);font-weight:800}
.egc-status.live::before{content:"";display:inline-block;width:4px;height:4px;border-radius:50%;background:var(--nb-red);margin-right:4px;animation:blink 1s infinite;vertical-align:middle}
.egc-tv{font-size:8px;font-weight:600;color:var(--nb-muted);background:#f0f2f5;padding:1px 5px;border-radius:3px}
.egc-teams{display:flex;flex-direction:column;gap:6px}
.egc-team-row{display:flex;align-items:center;gap:8px}
.egc-logo{width:30px;height:30px;border-radius:50%;background:#f0f2f5;overflow:hidden;flex-shrink:0;display:flex;align-items:center;justify-content:center}
.egc-logo img{width:100%;height:100%;object-fit:contain}
.egc-team-info{flex:1;min-width:0}
.egc-team-name{font-size:13px;font-weight:600;color:var(--nb-text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.egc-team-name.winner{font-weight:700}
.egc-record{font-size:9px;color:var(--nb-muted);margin-top:0}
.egc-networks{display:flex;flex-wrap:wrap;gap:2px;justify-content:flex-end}
.egc-network-pill{font-size:8px;font-weight:600;color:var(--nb-muted);background:#f0f2f5;padding:1px 4px;border-radius:3px;white-space:nowrap}
.egc-score{font-family:"Roboto Condensed",sans-serif;font-size:20px;font-weight:700;color:var(--nb-text);min-width:32px;text-align:right;flex-shrink:0;letter-spacing:-.5px}
.egc-score.winner{color:var(--nb-text)}
.egc-score.dash{color:var(--nb-muted);font-size:14px}
.egc-divider{height:1px;background:var(--nb-border2);margin:3px 0}
.egc-series{margin-top:6px;padding-top:6px;border-top:1px solid var(--nb-border2);font-size:9px;color:var(--nb-muted);font-style:italic}
.egc-leaders{margin-top:6px;padding-top:6px;border-top:1px solid var(--nb-border2);display:flex;gap:6px;flex-wrap:wrap}
.egc-leader{display:flex;align-items:center;gap:4px;font-size:9px;color:var(--nb-muted)}
.egc-leader-avatar{width:18px;height:18px;border-radius:50%;background:#f0f2f5;overflow:hidden;flex-shrink:0}
.egc-leader-avatar img{width:100%;height:100%;object-fit:cover}
.egc-leader-stat{color:var(--nb-text);font-weight:700}

/* EMPTY STATE */
.scoreboard-empty{padding:40px 30px;text-align:center;color:var(--nb-muted);font-size:12px;background:var(--nb-card);border:1px solid var(--nb-border);border-radius:8px}
.scoreboard-empty i{font-size:1.6rem;margin-bottom:8px;display:block;opacity:.25}

/* STANDINGS */
.standings-table{width:100%}
.standings-header{display:grid;grid-template-columns:28px 1fr 40px 40px 48px;padding:6px 12px;font-size:8px;font-weight:800;letter-spacing:1.2px;text-transform:uppercase;color:var(--nb-muted);border-bottom:1px solid var(--nb-border);background:#f8f9fb}
.standings-row{display:grid;grid-template-columns:28px 1fr 40px 40px 48px;padding:7px 12px;font-size:12px;color:var(--nb-text);align-items:center;border-bottom:1px solid var(--nb-border2);transition:background .1s}
.standings-row:last-child{border-bottom:none}
.standings-row:hover{background:rgba(200,16,46,0.03)}
.rank{font-family:"Roboto Condensed",sans-serif;font-size:13px;font-weight:700;color:var(--nb-muted)}
.rank.top3{color:var(--nb-red);font-weight:800}
.rank.p6{color:var(--nb-orange)}
.rank.p10{color:var(--nb-blue)}
.team-cell{display:flex;align-items:center;gap:6px}
.team-cell .team-logo-sm{width:22px;height:22px}
.team-cell strong{font-size:11px;color:var(--nb-text)}
.stat-cell{text-align:center;font-weight:600;color:var(--nb-muted)}
.stat-cell.w{color:var(--nb-red)}
.strk-w{color:#e67e22;font-weight:700}
.strk-l{color:var(--nb-red);font-weight:700}
.diff-pos{color:#e67e22}
.diff-neg{color:var(--nb-red)}
.conf-divider td{background:#f8f9fb;color:var(--nb-muted);font-size:9px;font-weight:800;letter-spacing:1px;text-transform:uppercase;padding:4px 10px;border-bottom:1px solid var(--nb-border)}
.standings-loading{padding:24px;text-align:center;color:var(--nb-muted);font-size:12px}
#standingsYear optgroup{font-weight:700}

/* ESPN SIDE-BY-SIDE STANDINGS */
.standings-conference-grid{display:grid;grid-template-columns:1fr 1fr;gap:0}
@media(max-width:900px){.standings-conference-grid{grid-template-columns:1fr}}
.standings-conference{border-right:1px solid var(--nb-border)}
.standings-conference:last-child{border-right:none}
.standings-conf-header{font-family:"Roboto Condensed",sans-serif;font-size:12px;font-weight:700;padding:9px 14px;background:linear-gradient(135deg,#f0f3f8,#fff);border-bottom:1px solid var(--nb-border);color:var(--nb-red);letter-spacing:.3px}
.standings-conf-header i{color:var(--nb-gold);margin-right:4px}
.espn-standings-table{width:100%;border-collapse:collapse;font-size:10px}
.espn-standings-table th{font-size:7px;font-weight:800;letter-spacing:1px;text-transform:uppercase;color:var(--nb-muted);padding:5px 4px;text-align:center;border-bottom:1px solid var(--nb-border);background:linear-gradient(135deg,#f8f9fb,#f0f2f5);white-space:nowrap}
.espn-standings-table th:first-child{padding-left:8px;text-align:center;width:20px}
.espn-standings-table th:nth-child(2){text-align:left;padding-left:3px}
.espn-standings-table td{padding:5px 4px;text-align:center;border-bottom:1px solid var(--nb-border2);white-space:nowrap;vertical-align:middle}
.espn-standings-table td:first-child{font-family:"Roboto Condensed",sans-serif;font-size:11px;font-weight:700;color:var(--nb-muted);padding-left:5px}
.espn-standings-table td:nth-child(2){text-align:left}
.espn-standings-table tbody tr{transition:background .08s}
.espn-standings-table tbody tr:hover{background:rgba(200,16,46,0.04)}
.espn-standings-table tbody tr:nth-child(even){background:rgba(0,0,0,0.015)}
.espn-standings-table .team-cell-s{display:flex;align-items:center;gap:5px}
.espn-standings-table .team-cell-s img{width:18px;height:18px;object-fit:contain;border-radius:50%;flex-shrink:0}
.espn-standings-table .team-abbr{font-weight:700;color:var(--nb-text);font-size:10px}
.espn-standings-table .team-full{font-size:8px;color:var(--nb-muted);display:block}
.espn-standings-table .stat-val{font-weight:600;color:var(--nb-text);font-size:10px}
.espn-standings-table .stat-val.w{color:var(--nb-red);font-weight:700}
.espn-standings-table .stat-val.l{color:var(--nb-muted)}
.espn-standings-table .stat-val.pct-pos{color:#e67e22;font-weight:700}
.espn-standings-table .stat-val.pct-neg{color:var(--nb-red);font-weight:700}
.espn-standings-table .stat-val.diff-pos{color:#e67e22}
.espn-standings-table .stat-val.diff-neg{color:var(--nb-red)}
.espn-standings-table .strk-w{color:#e67e22;font-weight:700}
.espn-standings-table .strk-l{color:var(--nb-red);font-weight:700}
.espn-standings-table .stat-val.ppg{color:var(--nb-text)}
.playoff-badge{display:inline-block;font-size:7px;font-weight:800;padding:1px 3px;border-radius:2px;letter-spacing:.2px;line-height:1.2}
.playoff-badge.z{background:linear-gradient(135deg,#c8102e,#ff4500);color:#fff}
.playoff-badge.y{background:linear-gradient(135deg,#005a30,#00a86b);color:#fff}
.playoff-badge.x{background:linear-gradient(135deg,var(--nb-blue),#2d5bbe);color:#fff}
.playoff-badge.pb{background:linear-gradient(135deg,#e67800,#ff8c00);color:#fff}
.playoff-badge.e{background:#e4e7ec;color:var(--nb-muted)}

/* PLAYERS */
.players-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(140px,1fr));gap:10px;padding:14px}
.player-card{background:var(--nb-card);border:1px solid var(--nb-border);border-radius:10px;padding:14px 10px 10px;text-align:center;transition:.15s;box-shadow:var(--nb-shadow)}
.player-card:hover{border-color:var(--nb-orange);transform:translateY(-3px);box-shadow:0 6px 20px rgba(0,0,0,0.1)}
.player-avatar{width:44px;height:44px;border-radius:50%;background:linear-gradient(135deg,#f0f2f5,#e4e7ec);margin:0 auto 6px;display:flex;align-items:center;justify-content:center;font-family:"Roboto Condensed",sans-serif;font-size:1rem;font-weight:700;color:var(--nb-text)}
.player-name{font-size:11px;font-weight:700;margin-bottom:2px;line-height:1.2;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.player-meta{font-size:9px;color:var(--nb-muted);margin-bottom:5px;display:flex;align-items:center;justify-content:center;gap:5px}
.player-meta img{width:14px;height:14px;object-fit:contain;border-radius:2px}
.player-stat{font-family:"Roboto Condensed",sans-serif;font-size:1.3rem;font-weight:700;background:linear-gradient(135deg,var(--nb-orange),var(--nb-red));-webkit-background-clip:text;-webkit-text-fill-color:transparent;line-height:1}
.player-stat-label{font-size:8px;color:var(--nb-muted);text-transform:uppercase;letter-spacing:.4px;margin-bottom:4px}
.player-stats-row{display:flex;justify-content:center;gap:8px;font-size:9px;color:var(--nb-muted);border-top:1px solid var(--nb-border2);padding-top:5px;margin-top:5px}
.player-stats-row span{display:flex;flex-direction:column;align-items:center;gap:1px}
.player-stats-row strong{color:var(--nb-text);font-size:10px}

/* NEWS */
.news-list{padding:8px;display:flex;flex-direction:column;gap:6px}
.news-item{display:flex;gap:10px;padding:10px;background:var(--nb-card);border:1px solid var(--nb-border);border-radius:8px;transition:.15s;cursor:pointer}
.news-item:hover{border-color:var(--nb-red);transform:translateY(-2px);box-shadow:0 4px 14px rgba(0,0,0,0.08)}
.news-img{width:64px;height:48px;border-radius:6px;background:linear-gradient(135deg,#f0f2f5,#e4e7ec);display:flex;align-items:center;justify-content:center;flex-shrink:0;overflow:hidden}
.news-img i{font-size:1.1rem;color:var(--nb-muted)}
.news-content{flex:1;min-width:0}
.news-tag{font-size:8px;font-weight:800;letter-spacing:.8px;text-transform:uppercase;color:var(--nb-red);margin-bottom:2px}
.news-title{font-size:12px;font-weight:600;line-height:1.2;margin-bottom:2px}
.news-meta{font-size:9px;color:var(--nb-muted)}

/* BRACKET */
.bracket-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:8px;padding:14px}
@media(max-width:768px){.bracket-grid{grid-template-columns:repeat(2,1fr)}}
.bracket-region{background:var(--nb-card2);border:1px solid var(--nb-border);border-radius:8px;padding:10px}
.bracket-region h4{font-family:"Roboto Condensed",sans-serif;font-size:11px;font-weight:700;color:var(--nb-red);margin-bottom:6px;letter-spacing:.4px}
.bracket-team{display:flex;justify-content:space-between;align-items:center;padding:4px 7px;border-radius:4px;font-size:11px;margin-bottom:3px}
.bracket-team:hover{background:rgba(200,16,46,0.04)}
.seed-num{color:var(--nb-muted);margin-right:4px;font-size:9px}

/* DRAFT */
.draft-header-row{display:grid;grid-template-columns:32px 100px 1fr 55px 45px 55px 35px repeat(5,38px);align-items:center;gap:4px;padding:5px 10px;font-size:8px;font-weight:700;letter-spacing:.6px;text-transform:uppercase;color:var(--nb-muted);border-bottom:1px solid var(--nb-border2)}
.draft-header-row .draft-stat-hdr{cursor:pointer;text-align:center;transition:color .15s;position:relative}
.draft-header-row .draft-stat-hdr:hover{color:var(--nb-text)}
.draft-header-row .draft-stat-hdr.active{color:var(--nb-red)}
.draft-header-row .draft-stat-hdr .draft-hdr-arrow{font-size:6px;display:none;margin-left:2px}
.draft-header-row .draft-stat-hdr.active .draft-hdr-arrow{display:inline}
.draft-round-label{grid-column:1/-1;padding:8px 10px 4px;font-size:9px;font-weight:700;letter-spacing:1.2px;text-transform:uppercase;color:var(--nb-muted);border-bottom:1px solid var(--nb-border2);background:#f8f9fb}
.draft-pick-row{display:grid;grid-template-columns:32px 100px 1fr 55px 45px 55px 35px 50px repeat(5,38px);align-items:center;gap:4px;padding:6px 10px;border-bottom:1px solid var(--nb-border2);transition:background .1s;font-size:11px}
@media(max-width:1200px){.draft-pick-row,.draft-header-row{grid-template-columns:32px 80px 1fr 55px 45px 55px 35px 50px}}
@media(max-width:1100px){.draft-pick-row,.draft-header-row{grid-template-columns:32px 60px 1fr 55px 45px 55px 35px}.draft-stat-col,.draft-header-row .draft-stat-hdr{display:none}}
@media(max-width:800px){.draft-pick-row,.draft-header-row{grid-template-columns:28px 40px 1fr 42px 35px}.draft-team-col,.draft-cls-col,.draft-header-row .draft-team-hdr,.draft-header-row .draft-cls-hdr,.draft-age-col,.draft-header-row .draft-age-hdr{display:none}}
@media(max-width:500px){.draft-pick-row,.draft-header-row{grid-template-columns:26px 1fr}.draft-team-col,.draft-ht-col,.draft-wt-col,.draft-header-row .draft-team-hdr,.draft-header-row .draft-ht-hdr,.draft-header-row .draft-wt-hdr{display:none}}
.draft-pick-row:hover{background:rgba(200,16,46,0.03)}
.draft-pick-num{font-family:"Roboto Condensed",sans-serif;font-size:12px;font-weight:700;color:var(--nb-muted);text-align:center;min-width:24px}
.draft-pick-num.top5{color:var(--nb-gold)}
.draft-pick-num.lottery{color:var(--nb-orange)}
.draft-team-col{display:flex;align-items:center;gap:5px;min-width:0;overflow:hidden}
.draft-team-col img{width:18px;height:18px;object-fit:contain;flex-shrink:0;border-radius:3px}
.draft-team-col .draft-team-name{font-size:9px;font-weight:600;color:var(--nb-text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.draft-player-cell{min-width:0;overflow:hidden;cursor:pointer}
.draft-player-name{font-weight:600;color:var(--nb-text);font-size:12px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;line-height:1.3;transition:color .15s}
.draft-player-cell:hover .draft-player-name{color:var(--nb-red)}
.draft-player-meta{font-size:9px;color:var(--nb-muted);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;line-height:1.2}
.draft-player-meta em{font-style:normal;color:var(--nb-orange);font-weight:600}
.draft-stat-col{font-size:10px;color:var(--nb-text);text-align:center;font-weight:600;font-variant-numeric:tabular-nums}
.draft-stat-col .draft-stat-sub{font-size:7px;color:var(--nb-muted);font-weight:400;display:block;text-transform:uppercase;letter-spacing:.3px}
.draft-stat-col.dim{color:var(--nb-muted)}
.draft-stat-col.q-good{color:#00a86b}
.draft-stat-col.q-great{color:#008050}
.draft-stat-col.q-bad{color:#e74c3c}
.draft-stat-col.q-terrible{color:#c0392b}
.draft-bust-badge{display:inline-block;font-size:7px;font-weight:700;padding:2px 5px;border-radius:3px;text-transform:uppercase;letter-spacing:.3px;white-space:nowrap}
.bust-steal{background:#1b5e20;color:#fff}
.bust-bad{background:#b71c1c;color:#fff}
.bust-injury{background:#e65100;color:#fff}
.tip-bust{margin:4px 0;font-size:10px;display:flex;align-items:center;gap:4px}
.tip-bust-reason{color:var(--nb-muted);font-size:9px}
.draft-toggle{display:flex;gap:2px;background:var(--nb-border2);border-radius:4px;padding:2px;margin-left:auto}
.draft-toggle button{background:none;border:none;padding:3px 8px;font-size:9px;font-weight:600;color:var(--nb-muted);border-radius:3px;cursor:pointer;transition:all .15s;font-family:inherit;line-height:1}
.draft-toggle button.active{background:var(--nb-card);color:var(--nb-text);box-shadow:0 1px 2px rgba(0,0,0,0.08)}
.draft-toggle button:hover:not(.active){color:var(--nb-text)}
.draft-ext-link{display:flex;align-items:center;gap:3px;padding:3px 7px;font-size:9px;font-weight:700;color:var(--nb-muted);text-decoration:none;border-radius:4px;transition:all .14s;white-space:nowrap}
.draft-ext-link:hover{color:var(--nb-red);background:rgba(200,16,46,0.06)}
.draft-player-cell{display:flex;align-items:center;gap:5px;min-width:0;overflow:hidden;cursor:pointer}
.draft-player-avatar{width:22px;height:22px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:8px;font-weight:700;color:#fff;flex-shrink:0;overflow:hidden}
.draft-player-avatar img{width:100%;height:100%;object-fit:cover}
.draft-college-logo{width:14px;height:14px;object-fit:contain;flex-shrink:0;border-radius:2px;vertical-align:middle;margin-right:1px}
.draft-player-info{min-width:0;overflow:hidden}
#draftTooltip{position:fixed;z-index:9999;background:#1a1a2e;color:#e8e8e8;border-radius:8px;padding:12px 14px;font-size:12px;line-height:1.5;box-shadow:0 8px 32px rgba(0,0,0,0.35);pointer-events:none;opacity:0;transition:opacity .12s;max-width:280px;font-family:system-ui,-apple-system,sans-serif}
#draftTooltip.visible{opacity:1}
#draftTooltip .tip-name{font-size:14px;font-weight:700;color:#fff;margin-bottom:1px}
#draftTooltip .tip-team{font-size:10px;color:#c0c0c0;margin-bottom:6px}
#draftTooltip .tip-stats{display:grid;grid-template-columns:1fr 1fr;gap:2px 12px}
#draftTooltip .tip-stat{display:flex;justify-content:space-between;gap:8px}
#draftTooltip .tip-stat .tip-label{color:#888}
#draftTooltip .tip-stat .tip-value{font-weight:600;color:#e8e8e8}
#draftTooltip .tip-stat .tip-value.q-good{color:#00e676}
#draftTooltip .tip-stat .tip-value.q-great{color:#00c853}
#draftTooltip .tip-stat .tip-value.q-bad{color:#ff5252}
#draftTooltip .tip-stat .tip-value.q-terrible{color:#d32f2f}

/* DRAFT SCOUTING */
.draft-scouting-row{border-top:1px solid var(--nb-border);background:var(--nb-card);border-radius:0 0 6px 6px;overflow:hidden;animation:draftScoutIn .25s ease}
@keyframes draftScoutIn{from{opacity:0;max-height:0}to{opacity:1;max-height:600px}}
.draft-scouting-card{position:relative;padding:12px 14px;display:flex;gap:14px;flex-wrap:wrap}
.draft-scouting-left{display:flex;flex-direction:column;align-items:center;gap:6px;min-width:120px;flex-shrink:0}
.draft-scouting-headshot{width:70px;height:70px;border-radius:50%;overflow:hidden;background:var(--nb-bg);display:flex;align-items:center;justify-content:center;flex-shrink:0;border:2px solid var(--nb-border)}
.draft-scouting-headshot img{width:100%;height:100%;object-fit:cover}
.draft-scouting-comp{font-size:9px;color:var(--nb-muted);text-align:center;line-height:1.4;font-weight:500}
.draft-scouting-comp strong{color:var(--nb-orange);font-weight:700}
.draft-scouting-right{flex:1;min-width:200px;display:flex;flex-direction:column;gap:8px}
.draft-scouting-section h4{font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:.8px;color:var(--nb-muted);margin:0 0 3px}
.draft-scouting-section p{font-size:10px;line-height:1.5;color:var(--nb-text);margin:0}
.draft-scouting-section ul{margin:0;padding:0 0 0 14px;font-size:10px;line-height:1.5;color:var(--nb-text)}
.draft-scouting-section ul li{margin-bottom:1px}
.draft-scouting-meta{display:flex;gap:8px;flex-wrap:wrap;margin-top:4px}
.draft-scouting-meta a{font-size:9px;color:var(--nb-red);text-decoration:none;font-weight:600}
.draft-scouting-meta a:hover{text-decoration:underline}
.draft-scouting-close{position:absolute;top:6px;right:8px;cursor:pointer;font-size:16px;color:var(--nb-muted);line-height:1;background:none;border:none;padding:2px 4px;border-radius:3px;font-family:system-ui,sans-serif}
.draft-scouting-close:hover{color:var(--nb-text);background:var(--nb-border2)}
.draft-scouting-card.dark .draft-scouting-close{color:rgba(255,255,255,0.3)}
.draft-scouting-card.dark .draft-scouting-close:hover{color:#fff;background:rgba(255,255,255,0.1)}

/* CONTRACTS */
.cap-banner{background:linear-gradient(135deg,var(--nb-card),#f8f9fb);border:1px solid var(--nb-border);border-radius:8px;overflow:hidden;display:flex;flex-wrap:wrap;box-shadow:var(--nb-shadow)}
.cap-stat{flex:1;min-width:110px;padding:10px 16px;border-right:1px solid var(--nb-border)}
.cap-stat:last-child{border-right:none}
.cap-stat-label{font-size:8px;font-weight:700;letter-spacing:1.2px;text-transform:uppercase;color:var(--nb-muted);margin-bottom:3px}
.cap-stat-value{font-family:"Roboto Condensed",sans-serif;font-size:18px;font-weight:700;color:var(--nb-text);line-height:1}
.cap-stat-value.green{color:#00a86b}
.cap-stat-value.orange{color:var(--nb-orange)}
.cap-stat-value.gold{color:var(--nb-gold)}
.cap-stat-sub{font-size:9px;color:var(--nb-muted);margin-top:2px}
.sc-sub-tabs{display:flex;gap:0;border-bottom:1px solid var(--nb-border);background:linear-gradient(135deg,#f8f9fb,#fff);overflow-x:auto}
.sc-sub-tabs::-webkit-scrollbar{display:none}
.sc-sub-tab{padding:9px 16px;font-size:11px;font-weight:600;color:var(--nb-muted);border-bottom:2px solid transparent;cursor:pointer;white-space:nowrap;transition:all .14s}
.sc-sub-tab:hover{color:var(--nb-text)}
.sc-sub-tab.active{color:var(--nb-red);border-bottom-color:var(--nb-red)}
.sc-sub-panel{display:none}
.sc-sub-panel.visible{display:block}
.sc-toolbar{display:flex;align-items:center;gap:8px;flex-wrap:wrap;padding:9px 14px;border-bottom:1px solid var(--nb-border2);background:#f8f9fb}
.sc-search{position:relative;flex:1;min-width:140px;max-width:220px}
.sc-search i{position:absolute;left:8px;top:50%;transform:translateY(-50%);color:var(--nb-muted);font-size:10px}
.sc-search input{width:100%;background:#f0f2f5;border:1px solid var(--nb-border);border-radius:5px;padding:6px 8px 6px 24px;font-size:11px;color:var(--nb-text);font-family:inherit;outline:none;transition:border-color .15s}
.sc-search input:focus{border-color:var(--nb-red)}
.sc-search input::placeholder{color:var(--nb-muted)}
.sc-filter-tabs{display:flex;gap:3px;flex-wrap:wrap}
.sc-filter-tab{padding:4px 9px;border-radius:4px;font-size:10px;font-weight:600;color:var(--nb-muted);background:#f0f2f5;border:1px solid var(--nb-border);transition:all .12s;cursor:pointer}
.sc-filter-tab:hover{color:var(--nb-text);background:#e4e7ec}
.sc-filter-tab.active{background:var(--nb-red);border-color:var(--nb-red);color:#fff;box-shadow:0 1px 6px rgba(200,16,46,0.2)}
.sc-select{background:#f0f2f5;border:1px solid var(--nb-border);border-radius:5px;padding:5px 8px;font-size:10px;font-weight:600;color:var(--nb-text);font-family:inherit;outline:none;cursor:pointer}
.sc-select:focus{border-color:var(--nb-red)}
.standings-decade-btn{flex-shrink:0;padding:4px 12px;border-radius:4px;font-size:11px;font-weight:600;color:var(--nb-muted);border:1px solid var(--nb-border);cursor:pointer;transition:all .12s;white-space:nowrap;background:var(--nb-card)}
.standings-decade-btn:hover{color:var(--nb-text);border-color:var(--nb-red)}
.standings-decade-btn.active{color:#fff;background:var(--nb-red);border-color:var(--nb-red)}
.sc-select option{background:#fff;color:#111;font-weight:500}
.sc-select optgroup{background:#e8e8ee;color:#222;font-weight:700}
.sc-select optgroup option{background:#fff;color:#111;font-weight:500;padding:3px 6px}
.table-wrap{overflow-x:auto}
.sc-table{width:100%;border-collapse:collapse}
.sc-table th{padding:7px 11px;font-size:8px;font-weight:800;letter-spacing:1px;text-transform:uppercase;color:var(--nb-muted);text-align:left;background:linear-gradient(135deg,#f8f9fb,#f0f2f5);border-bottom:1px solid var(--nb-border);white-space:nowrap;cursor:pointer;user-select:none}
.sc-table th:hover{color:var(--nb-text)}
.sc-table th.sort-asc::after{content:" ▲";font-size:7px}
.sc-table th.sort-desc::after{content:" ▼";font-size:7px}
.sc-table th.num,.sc-table td.num{text-align:right}
.sc-table td{padding:8px 11px;border-bottom:1px solid var(--nb-border2);font-size:11px;vertical-align:middle;white-space:nowrap}
.sc-table tr:last-child td{border-bottom:none}
.sc-table tbody tr{transition:background .08s}
.sc-table tbody tr:hover{background:rgba(200,16,46,0.03)}
.sc-table tbody tr.highlighted{background:rgba(200,16,46,0.06)}
.p-cell{display:flex;align-items:center;gap:7px}
.p-avatar{width:26px;height:26px;border-radius:50%;background:linear-gradient(135deg,#f0f2f5,#e4e7ec);display:flex;align-items:center;justify-content:center;font-size:11px;color:var(--nb-muted);flex-shrink:0}
.p-name{font-size:11px;font-weight:600;color:var(--nb-blue);display:block}
.p-name:hover{text-decoration:underline}
.p-pos{font-size:9px;color:var(--nb-muted)}
.tl-cell{display:flex;align-items:center;gap:5px}
.tl-cell img{width:18px;height:18px;object-fit:contain}
.sal{font-family:"Roboto Condensed",sans-serif;font-size:13px;font-weight:600}
.sal-max{color:var(--nb-gold)}
.sal-high{color:#00a86b}
.sal-mid{color:var(--nb-text)}
.sal-low{color:var(--nb-muted)}
.ct{display:inline-block;padding:1px 6px;border-radius:3px;font-size:8px;font-weight:700;letter-spacing:.4px;text-transform:uppercase}
.ct-supermax{background:rgba(255,215,0,0.15);color:#b8950a}
.ct-max{background:rgba(255,215,0,0.1);color:#8a7000}
.ct-rookie{background:rgba(200,16,46,0.08);color:var(--nb-red)}
.ct-vet{background:rgba(0,168,107,0.08);color:#00a86b}
.ct-two-way{background:rgba(124,77,255,0.08);color:#5e35b1}
.ct-standard{background:#f0f2f5;color:var(--nb-muted)}
.ct-ro{background:rgba(200,16,46,0.08);color:var(--nb-red)}
.opt{font-size:8px;padding:1px 4px;border-radius:2px;font-weight:700;text-transform:uppercase}
.opt-po{background:rgba(0,168,107,0.08);color:#00a86b}
.opt-to{background:rgba(200,16,46,0.08);color:var(--nb-red)}
.opt-etd{background:rgba(200,16,46,0.08);color:var(--nb-red)}
.cap-bar-wrap{display:flex;align-items:center;gap:6px;min-width:100px}
.cap-bar-track{flex:1;height:4px;border-radius:2px;background:#e4e7ec}
.cap-bar-fill{height:100%;border-radius:2px;transition:width .4s ease}
.team-cap-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:12px;padding:14px}
.team-cap-card{background:var(--nb-card);border:1px solid var(--nb-border);border-radius:8px;padding:12px;cursor:pointer;transition:all .14s;box-shadow:var(--nb-shadow)}
.team-cap-card:hover{border-color:var(--nb-red);box-shadow:0 6px 20px rgba(0,0,0,0.1)}
.tcc-header{display:flex;align-items:center;gap:8px;margin-bottom:10px}
.tcc-header img{width:28px;height:28px;object-fit:contain}
.tcc-name{font-family:"Roboto Condensed",sans-serif;font-size:13px;font-weight:700;color:var(--nb-text)}
.tcc-conf{font-size:9px;color:var(--nb-muted)}
.tcc-row{display:flex;justify-content:space-between;align-items:center;padding:3px 0;border-bottom:1px solid var(--nb-border2);font-size:10px}
.tcc-row:last-child{border-bottom:none;padding-bottom:0}
.tcc-label{color:var(--nb-muted)}
.tcc-val{font-weight:600}
.tcc-val.over{color:var(--nb-red)}
.tcc-val.under{color:#00a86b}
.tcc-val.warning{color:var(--nb-gold)}
.tcc-bar-wrap{margin-top:8px}
.tcc-bar-label{display:flex;justify-content:space-between;font-size:8px;color:var(--nb-muted);margin-bottom:2px}
.tcc-bar-track{height:4px;border-radius:2px;background:#e4e7ec}
.tcc-bar-fill{height:100%;border-radius:2px}
.sb-bars{padding:14px;display:flex;flex-direction:column;gap:9px}
.sb-row{display:flex;align-items:center;gap:8px}
.sb-label{width:100px;font-size:10px;color:var(--nb-muted);text-align:right;flex-shrink:0}
.sb-track{flex:1;height:16px;background:#e4e7ec;border-radius:3px;overflow:hidden}
.sb-fill{height:100%;border-radius:3px;display:flex;align-items:center;justify-content:flex-end;padding-right:6px;font-size:9px;font-weight:700;color:#fff;transition:width .5s ease}
.sb-total{width:60px;font-family:"Roboto Condensed",sans-serif;font-size:12px;font-weight:600;flex-shrink:0}
.legend{display:flex;gap:12px;flex-wrap:wrap;padding:8px 14px;border-top:1px solid var(--nb-border2)}
.legend-item{display:flex;align-items:center;gap:3px;font-size:9px;color:var(--nb-muted)}
.legend-dot{width:6px;height:6px;border-radius:50%}

/* FA TABLE */
#faTbody tr{transition:all .2s ease;border-left:3px solid transparent}
#faTbody tr:hover{border-left-color:var(--nb-red);background:rgba(200,16,46,0.04)!important;transform:translateX(2px)}
#faTbody tr:nth-child(even){background:rgba(0,0,0,0.015)}
#faTbody tr:nth-child(odd){background:transparent}
#faPosFilter .sc-filter-tab,#faExpFilter .sc-filter-tab{font-size:11px;padding:3px 8px;margin:0 2px}
.sc-toolbar-row{display:flex;gap:6px;flex-wrap:wrap;padding:5px 14px 8px;align-items:center}
.sc-toolbar-row .sc-filter-tabs{display:flex;gap:2px;background:var(--nb-bg);border-radius:6px;padding:2px}
.sc-toolbar-row .sc-filter-tab{background:transparent;border:none;color:var(--nb-muted);cursor:pointer;font-family:"Roboto Condensed",sans-serif;font-weight:600;font-size:11px;text-transform:uppercase;letter-spacing:.4px;padding:4px 10px;border-radius:5px;transition:all .2s}
.sc-toolbar-row .sc-filter-tab:hover{color:var(--nb-text);background:rgba(200,16,46,0.05)}
.sc-toolbar-row .sc-filter-tab.active{background:linear-gradient(135deg,var(--nb-red),var(--nb-orange));color:#fff;box-shadow:0 2px 8px rgba(200,16,46,0.25)}
#faExpFilter .sc-filter-tab.active{background:linear-gradient(135deg,#7c4dff,#2979ff);box-shadow:0 2px 8px rgba(124,77,255,0.25)}
.ct-badge{display:inline-block;border-radius:3px;font-weight:600}

/* RESPONSIVE */
@media(max-width:700px){
.nba-hero{padding:14px 14px 12px}
.nba-hero-text h1{font-size:1.4rem}
.hero-cap-row{display:none}
.nba-content{padding:10px}
.sc-table td,.sc-table th{padding:5px 7px}
.cap-banner{flex-direction:column}
.cap-stat{border-right:none;border-bottom:1px solid var(--nb-border)}
}
</style>
</head>
<body>

<!-- TOPBAR -->
<header class="nba-topbar">
  <a href="index.html" class="back-link"><i class="fas fa-arrow-left"></i> Sports Sync</a>
  <span class="divider"></span>
  <span class="league-badge">NBA</span>
  <span class="page-title">NBA Games</span>
  <span class="live-pill" id="livePill"><span class="dot"></span> LIVE</span>
  <span class="spacer"></span>
  <div class="topbar-links">
    <a href="https://www.nba.com" target="_blank" class="topbar-link"><i class="fas fa-external-link-alt"></i> NBA.com</a>
    <a href="https://www.espn.com/nba/scoreboard" target="_blank" class="topbar-link"><i class="fas fa-external-link-alt"></i> ESPN</a>
  </div>
</header>

<!-- HERO -->
<section class="nba-hero">
  <div class="nba-hero-inner">
    <div class="nba-hero-top">
      <div class="nba-hero-text">
        <h1>NBA <em>Live</em></h1>
        <p>Real-time scores, standings, stats &amp; more — <a href="#" id="refreshLink">Refresh</a></p>
      </div>
      <div class="hero-cap-row">
        <div class="hero-cap-stat"><div class="hero-cap-label">Salary Cap</div><div class="hero-cap-value gold" id="heroCap">$154.6M</div></div>
        <div class="hero-cap-stat"><div class="hero-cap-label">Luxury Tax</div><div class="hero-cap-value orange" id="heroTax">$187.9M</div></div>
        <div class="hero-cap-stat"><div class="hero-cap-label">1st Apron</div><div class="hero-cap-value green" id="heroApron">$195.9M</div></div>
        <div class="hero-cap-stat"><div class="hero-cap-label">2nd Apron</div><div class="hero-cap-value" id="heroApron2">$207.8M</div></div>
      </div>
    </div>
  </div>
</section>

<!-- SUBNAV -->
<nav class="nba-subnav" id="subnav">
  <div class="nba-tab active" data-tab="scores"><i class="fas fa-basketball-ball"></i> Scores</div>
  <div class="nba-tab" data-tab="standings"><i class="fas fa-list-ol"></i> Standings</div>
  <div class="nba-tab" data-tab="players"><i class="fas fa-users"></i> Players</div>
  <div class="nba-tab" data-tab="news"><i class="fas fa-newspaper"></i> News</div>
  <div class="nba-tab" data-tab="contracts"><i class="fas fa-file-invoice-dollar"></i> Contracts</div>
  <div class="nba-tab" data-tab="bracket"><i class="fas fa-trophy"></i> Bracket</div>
  <div class="nba-tab" data-tab="draft"><i class="fas fa-user-graduate"></i> Draft</div>
</nav>

<!-- BODY LAYOUT -->
<div class="nba-body">

  <!-- LEFT NAV -->
  <nav class="nba-leftnav" id="leftnav">
    <div class="leftnav-group">
      <div class="leftnav-group-label">NBA</div>
      <div class="leftnav-item active" data-tab="scores"><i class="fas fa-basketball-ball"></i> Scores</div>
      <div class="leftnav-item" data-tab="standings"><i class="fas fa-list-ol"></i> Standings</div>
      <div class="leftnav-item" data-tab="players"><i class="fas fa-users"></i> Players</div>
      <div class="leftnav-item" data-tab="news"><i class="fas fa-newspaper"></i> News</div>
      <div class="leftnav-item" data-tab="contracts"><i class="fas fa-file-invoice-dollar"></i> Contracts</div>
    </div>
    <div class="leftnav-group">
      <div class="leftnav-group-label">Postseason</div>
      <div class="leftnav-item" data-tab="bracket"><i class="fas fa-trophy"></i> Bracket</div>
      <div class="leftnav-item" data-tab="draft"><i class="fas fa-user-graduate"></i> Draft</div>
    </div>
    <div class="leftnav-group">
      <div class="leftnav-group-label">Links</div>
      <a href="https://www.nba.com/stats" target="_blank" class="leftnav-item"><i class="fas fa-chart-bar"></i> NBA Stats</a>
      <a href="https://www.espn.com/nba/scoreboard" target="_blank" class="leftnav-item"><i class="fas fa-external-link-alt"></i> ESPN</a>
    </div>
  </nav>

  <!-- CONTENT -->
  <main class="nba-content">

    <!-- SCORES PANEL -->
    <section class="nba-panel active" id="panel-scores">
      <div class="sc-card">
        <div class="sc-card-header">
          <span class="sc-card-title"><i class="fas fa-calendar-alt"></i> Select Date</span>
          <span class="sc-card-meta"><i class="far fa-clock"></i> <span id="todayLabel">Today</span></span>
        </div>
        <div class="sds-wrap">
          <button class="sds-scroll-btn" id="sdsPrev"><i class="fas fa-chevron-left"></i></button>
          <div class="scoreboard-date-strip" id="dateStrip"></div>
          <button class="sds-scroll-btn" id="sdsNext"><i class="fas fa-chevron-right"></i></button>
        </div>
      </div>
      <div class="scores-two-col">
        <div class="scores-main">
          <div class="sc-card">
            <div class="filter-bar" id="filterBar">
              <button class="filter-btn active" data-filter="all">All</button>
              <button class="filter-btn" data-filter="live">Live</button>
              <button class="filter-btn" data-filter="final">Final</button>
              <button class="filter-btn" data-filter="scheduled">Scheduled</button>
            </div>
            <div class="espn-scoreboard-grid" id="scoreboardGrid"><div class="scoreboard-empty"><i class="fas fa-basketball-ball"></i> Loading games...</div></div>
          </div>
        </div>
        <aside class="scores-sidebar" style="display:flex;flex-direction:column;gap:16px">
          <div class="sc-card">
            <div class="sc-card-header"><span class="sc-card-title"><i class="fas fa-list-ol"></i> Eastern Conference</span><span class="sc-card-meta">Top 8</span></div>
            <div id="standingsSidebar"></div>
          </div>
          <div class="sc-card">
            <div class="sc-card-header"><span class="sc-card-title"><i class="fas fa-list-ol"></i> Western Conference</span><span class="sc-card-meta">Top 8</span></div>
            <div id="standingsSidebarWest"></div>
          </div>
        </aside>
      </div>
    </section>

    <!-- STANDINGS PANEL -->
    <section class="nba-panel" id="panel-standings">
      <div class="sc-card">
        <div class="sc-card-header">
          <span class="sc-card-title"><i class="fas fa-list-ol"></i> NBA Standings</span>
          <div style="display:flex;gap:8px;align-items:center">
            <select id="standingsYear" class="sc-select"></select>
          </div>
        </div>
        <div class="standings-decade-bar" id="standingsDecadeBar" style="display:flex;gap:3px;padding:6px 14px;border-bottom:1px solid var(--nb-border2);overflow-x:auto"></div>
        <div id="seasonHighlightsBar" style="margin:0 0 10px;display:flex;gap:20px;flex-wrap:wrap;padding:0 14px"></div>
        <div class="standings-conference-grid">
          <div class="standings-conference">
            <div class="standings-conf-header"><i class="fas fa-star"></i> Eastern Conference</div>
            <div id="standingsEastContainer" style="overflow-x:auto"><div class="standings-loading">Loading...</div></div>
          </div>
          <div class="standings-conference">
            <div class="standings-conf-header"><i class="fas fa-star"></i> Western Conference</div>
            <div id="standingsWestContainer" style="overflow-x:auto"><div class="standings-loading">Loading...</div></div>
          </div>
        </div>
      </div>
    </section>

    <!-- PLAYERS PANEL -->
    <section class="nba-panel" id="panel-players">
      <div class="sc-card">
        <div class="sc-card-header">
          <span class="sc-card-title"><i class="fas fa-users"></i> NBA Players</span>
          <div style="display:flex;gap:8px;align-items:center">
            <select id="playersYear" class="sc-select"></select>
            <select id="playersCat" class="sc-select">
              <option value="ppg">Points</option>
              <option value="apg">Assists</option>
              <option value="rpg">Rebounds</option>
            </select>
          </div>
        </div>
        <div class="players-grid" id="playersGrid"><div class="scoreboard-empty"><i class="fas fa-users"></i> Select a year</div></div>
      </div>
    </section>

    <!-- NEWS PANEL -->
    <section class="nba-panel" id="panel-news">
      <div class="sc-card">
        <div class="sc-card-header">
          <span class="sc-card-title"><i class="fas fa-newspaper"></i> NBA News</span>
          <span class="sc-card-meta"><a href="https://www.espn.com/nba/" target="_blank" style="color:var(--nb-red);font-weight:600">ESPN NBA <i class="fas fa-external-link-alt"></i></a></span>
        </div>
        <div class="news-list" id="newsList"><div class="scoreboard-empty"><i class="fas fa-newspaper"></i> Loading news...</div></div>
      </div>
    </section>

    <!-- CONTRACTS PANEL -->
    <section class="nba-panel" id="panel-contracts">
      <div class="cap-banner" id="capBanner"></div>
      <div class="sc-card">
        <div class="sc-sub-tabs">
          <div class="sc-sub-tab active" data-contracts-tab="salaries">Player Salaries</div>
          <div class="sc-sub-tab" data-contracts-tab="team">Team Cap</div>
          <div class="sc-sub-tab" data-contracts-tab="freeagents">Free Agents</div>
        </div>
        <div id="contractsContent"></div>
      </div>
    </section>

    <!-- BRACKET PANEL -->
    <section class="nba-panel" id="panel-bracket">
      <div class="sc-card">
        <div class="sc-card-header">
          <span class="sc-card-title"><i class="fas fa-trophy"></i> March Madness Bracket</span>
          <span class="sc-card-meta">2025 NCAA Tournament</span>
        </div>
        <div class="bracket-grid" id="bracketGrid"><div class="scoreboard-empty" style="grid-column:1/-1"><i class="fas fa-trophy"></i> Loading bracket...</div></div>
      </div>
    </section>

    <!-- DRAFT PANEL -->
    <section class="nba-panel" id="panel-draft">
      <div class="sc-card">
        <div class="sc-card-header">
          <span class="sc-card-title"><i class="fas fa-user-graduate"></i> NBA Draft</span>
          <div style="display:flex;gap:8px;align-items:center">
            <div class="draft-toggle" id="draftStatToggle">
              <button data-view="perGame" class="active">Per Game</button>
              <button data-view="per36">Per 36</button>
              <button data-view="advanced">Advanced</button>
            </div>
            <select id="draftYear" class="sc-select"></select>
            <a href="https://www.tankathon.com/mock-draft" target="_blank" class="draft-ext-link"><i class="fas fa-list"></i> Mock</a>
            <a href="https://www.tankathon.com/big-board" target="_blank" class="draft-ext-link"><i class="fas fa-chart-bar"></i> Board</a>
          </div>
        </div>
        <div style="display:flex;justify-content:flex-end;gap:10px;padding:5px 10px;font-size:8px;letter-spacing:.4px;text-transform:uppercase;color:var(--nb-muted)">
          <span style="color:#00a86b;font-weight:600">&#9608; Good</span>
          <span style="color:#008050;font-weight:600">&#9608; Great</span>
          <span style="color:#e74c3c;font-weight:600">&#9608; Bad</span>
          <span style="color:#c0392b;font-weight:600">&#9608; Terrible</span>
        </div>
        <div id="draftTableContainer"><div class="scoreboard-empty"><i class="fas fa-user-graduate"></i> Select a year</div></div>
      </div>
    </section>

  </main>
</div>
