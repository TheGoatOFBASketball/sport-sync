/* ===== STATE ===== */
const NBA_STATE = {
  currentTab: 'scores',
  selectedDate: (() => { const d=new Date(); return d.getFullYear()+''+String(d.getMonth()+1).padStart(2,'0')+String(d.getDate()).padStart(2,'0'); })(),
  activeFilter: 'all',
  contractsTab: 'salaries'
};



function getStandingsData(year){
  const bbref=window.BBREF_STANDINGS;
  if(!bbref||!bbref[year])return null;
  const yd=bbref[year];
  const data={};
  ['e','w'].forEach(c=>{
    if(yd[c]){
      data[c]=yd[c].map(t=>({
        team:t.team,wins:t.wins,losses:t.losses,pct:t.pct,gb:t.gb==='—'?'—':t.gb,
        ppg:t.ppg,opp:t.opp,diff:t.diff,abbr:teamAbbr(t.team)
      }));
    }
  });
  return data.e||data.w?data:null;
}

/* ===== DATE UTILITIES ===== */
function toDateStr(d){return d.getFullYear()+''+String(d.getMonth()+1).padStart(2,'0')+String(d.getDate()).padStart(2,'0')}
function fromDateStr(s){return new Date(parseInt(s.slice(0,4)),parseInt(s.slice(4,6))-1,parseInt(s.slice(6,8)))}
function formatLabel(d){const m=d.toLocaleDateString('en',{month:'short'});return m+' '+d.getDate()}
function formatDay(d){return d.toLocaleDateString('en',{weekday:'short'}).slice(0,3)}
function isToday(s){const d=new Date();return s===toDateStr(d)}
function isYesterday(s){const d=new Date();d.setDate(d.getDate()-1);return s===toDateStr(d)}
function isTomorrow(s){const d=new Date();d.setDate(d.getDate()+1);return s===toDateStr(d)}
function getDateLabel(s){if(isToday(s))return'Today';if(isYesterday(s))return'Yesterday';if(isTomorrow(s))return'Tomorrow';return''}
function getRelativeLabel(d){const n=new Date();const t=new Date(n);t.setDate(t.getDate()+1);const y=new Date(n);y.setDate(y.getDate()-1);const s=toDateStr(d);if(s===toDateStr(n))return'Today';if(s===toDateStr(y))return'Yesterday';if(s===toDateStr(t))return'Tomorrow';return''}

/* ===== DATE STRIP ===== */
function renderDateStrip(selected){
  const strip=document.getElementById('dateStrip');if(!strip)return;
  const today=new Date();
  let html='';
  const days=14;
  for(let i=-7;i<days;i++){
    const d=new Date(today);d.setDate(d.getDate()+i);
    const ds=toDateStr(d);
    const active=ds===selected?'active':'';
    const label=getRelativeLabel(d);
    html+='<div class="score-date-chip '+active+'" data-date="'+ds+'">';
    html+='<span class="chip-day">'+(label||formatDay(d))+'</span>';
    html+='<span class="chip-date">'+d.getDate()+'</span>';
    html+='</div>';
  }
  strip.innerHTML=html;
  strip.querySelectorAll('.score-date-chip').forEach(el=>{
    el.addEventListener('click',function(){
      const date=this.dataset.date;
      document.querySelectorAll('.score-date-chip').forEach(c=>c.classList.remove('active'));
      this.classList.add('active');
      NBA_STATE.selectedDate=date;
      const label=document.getElementById('todayLabel');
      if(label)label.textContent=getDateLabel(date)||formatLabel(fromDateStr(date));
      loadScores(date);
    });
  });
  const activeChip=strip.querySelector('.score-date-chip.active');
  if(activeChip)activeChip.scrollIntoView({behavior:'smooth',inline:'center',block:'nearest'});
  const prevBtn=document.getElementById('sdsPrev');
  const nextBtn=document.getElementById('sdsNext');
  if(prevBtn)prevBtn.onclick=()=>{strip.scrollLeft-=200};
  if(nextBtn)nextBtn.onclick=()=>{strip.scrollLeft+=200};
}

/* ===== TEAM LOGO HELPER ===== */
function teamLogoHTML(abbr,size,year){
  if(!size)size=36;
  const eraKey=teamEraLogo(abbr,year);
  const src=eraKey&&YEAR_SPECIFIC_LOGOS[eraKey]?YEAR_SPECIFIC_LOGOS[eraKey]:HISTORICAL_LOGOS[abbr];
  if(src)return '<img src="'+src+'" alt="'+abbr+'" style="width:'+size+'px;height:'+size+'px;object-fit:contain">';
  const espnAbbr=ESPN_CDN_ABBR[abbr]||ESPN_CDN_ABBR[FRANCHISE_MAP[abbr]];
  if(espnAbbr)return '<img src="'+ESPN_CDN+espnAbbr+'.png" alt="'+abbr+'" style="width:'+size+'px;height:'+size+'px;object-fit:contain">';
  const logos=window.TeamLogos;
  if(logos&&logos.nba&&logos.nba[abbr]&&logos.nba[abbr].logo){
    return '<img src="'+logos.nba[abbr].logo+'" alt="'+abbr+'" style="width:'+size+'px;height:'+size+'px;object-fit:contain">';
  }
  return '<span style="font-weight:700;font-size:'+(size/2)+'px;color:var(--nb-muted)">'+abbr+'</span>';
}

/* ===== ESPN API FETCH ===== */
async function fetchJSON(url){
  try{
    const res=await fetch(url);
    if(!res.ok)throw new Error('HTTP '+res.status);
    return await res.json();
  }catch(e){console.warn('fetch error:',url,e.message);return null}
}

/* ===== SCORES ===== */
async function loadScores(date){
  const grid=document.getElementById('scoreboardGrid');
  if(!grid)return;
  grid.innerHTML='<div class="scoreboard-empty"><i class="fas fa-basketball-ball"></i> Loading games...</div>';
  try{
    const api=window.SPORTSYNC_API;
    let data=null;
    if(api&&api.ESPN){
      data=await api.ESPN.getScoreboard('nba',date);
    }else{
      data=await fetchJSON('https://site.api.espn.com/apis/site/v2/sports/basketball/nba/scoreboard?dates='+date);
    }
    if(data&&data.events&&data.events.length){
      const games=api&&api.ESPN&&api.ESPN.parse?api.ESPN.parse.scoreboard(data):parseGames(data);
      renderGames(games);
    }else{
      grid.innerHTML='<div class="scoreboard-empty"><i class="fas fa-basketball-ball"></i> No games scheduled for this date</div>';
    }
  }catch(e){
    grid.innerHTML='<div class="scoreboard-empty"><i class="fas fa-exclamation-triangle"></i> Error loading scores</div>';
  }
}

function parseGames(data){
  if(!data||!data.events)return[];
  return data.events.map(event=>{
    const comp=event.competitions[0];
    const home=comp.competitors.find(c=>c.homeAway==='home');
    const away=comp.competitors.find(c=>c.homeAway==='away');
    const st=event.status;
    return{
      id:event.id,name:event.name,date:event.date,
      completed:st.type.completed,period:st.period,clock:st.displayClock,
      state:st.type.state,detail:st.type.detail,shortDetail:st.type.shortDetail,
      home:{id:home?.id,name:home?.team?.shortDisplayName,fullName:home?.team?.displayName,abbr:home?.team?.abbreviation,logo:home?.team?.logo,score:home?.score,winner:home?.winner,record:home?.records?.[0]?.summary},
      away:{id:away?.id,name:away?.team?.shortDisplayName,fullName:away?.team?.displayName,abbr:away?.team?.abbreviation,logo:away?.team?.logo,score:away?.score,winner:away?.winner,record:away?.records?.[0]?.summary},
      venue:comp.venue?.fullName,broadcast:comp.broadcasts?.[0]?.names?.[0],
      odds:comp.odds?.[0]?.details,overUnder:comp.odds?.[0]?.overUnder
    };
  });
}

function renderGames(games){
  const grid=document.getElementById('scoreboardGrid');
  if(!grid)return;
  if(!games||!games.length){
    grid.innerHTML='<div class="scoreboard-empty"><i class="fas fa-basketball-ball"></i> No games scheduled</div>';
    return;
  }
  const filter=NBA_STATE.activeFilter;
  let filtered=games;
  if(filter==='live')filtered=games.filter(g=>g.state==='in'||g.state==='live');
  else if(filter==='final')filtered=games.filter(g=>g.completed);
  else if(filter==='scheduled')filtered=games.filter(g=>g.state==='pre'||(!g.completed&&g.state!=='in'));
  if(!filtered.length){
    grid.innerHTML='<div class="scoreboard-empty"><i class="fas fa-filter"></i> No '+filter+' games</div>';
    return;
  }
  grid.innerHTML=filtered.map(g=>renderGameCard(g)).join('');
}

function renderGameCard(g){
  const isLive=g.state==='in'||g.state=='live';
  const isFinal=g.completed;
  const cls=(isLive?' is-live':'')+(isFinal?' is-final':'');
  let statusText=g.detail||g.shortDetail||'';
  if(isLive&&g.clock)statusText=g.clock+' '+('0'+g.period).slice(-1);
  const homeScore=isLive||isFinal?g.home.score:'';
  const awayScore=isLive||isFinal?g.away.score:'';
  const homeWin=isFinal&&g.home.winner;
  const awayWin=isFinal&&g.away.winner;
  const homeLogo=teamLogoHTML(g.home.abbr,36);
  const awayLogo=teamLogoHTML(g.away.abbr,36);
  return '<div class="espn-game-card'+cls+'" onclick="window.open(\'https://www.espn.com/nba/scoreboard\',\'_blank\')">'+
    '<div class="egc-header"><span class="egc-status'+(isLive?' live':'')+'">'+(isLive?'LIVE':statusText||(isFinal?'Final':g.shortDetail||'Scheduled'))+'</span>'+
    (g.broadcast?'<span class="egc-tv">'+g.broadcast+'</span>':'')+'</div>'+
    '<div class="egc-teams">'+
    '<div class="egc-team-row"><div class="egc-logo">'+awayLogo+'</div><div class="egc-team-info"><div class="egc-team-name'+(awayWin?' winner':'')+'">'+g.away.name+'</div>'+(g.away.record?'<div class="egc-record">'+g.away.record+'</div>':'')+'</div>'+
    '<div class="egc-score'+(awayWin?' winner':'')+'">'+(awayScore||'')+'</div></div>'+
    '<div class="egc-team-row"><div class="egc-logo">'+homeLogo+'</div><div class="egc-team-info"><div class="egc-team-name'+(homeWin?' winner':'')+'">'+g.home.name+'</div>'+(g.home.record?'<div class="egc-record">'+g.home.record+'</div>':'')+'</div>'+
    '<div class="egc-score'+(homeWin?' winner':'')+'">'+(homeScore||'')+'</div></div>'+
    '</div>'+
    (g.odds?'<div class="egc-divider"></div><div style="font-size:10px;color:var(--nb-muted);margin-top:6px">'+g.odds+(g.overUnder?' | O/U '+g.overUnder:'')+'</div>':'')+
    '</div>';
}

/* ===== FILTER BAR ===== */
function initFilterBar(){
  const bar=document.getElementById('filterBar');
  if(!bar)return;
  bar.querySelectorAll('.filter-btn').forEach(btn=>{
    btn.addEventListener('click',function(){
      bar.querySelectorAll('.filter-btn').forEach(b=>b.classList.remove('active'));
      this.classList.add('active');
      NBA_STATE.activeFilter=this.dataset.filter;
      const grid=document.getElementById('scoreboardGrid');
      if(grid&&grid.dataset.games){
        try{renderGames(JSON.parse(grid.dataset.games))}catch(e){}
      }
      loadScores(NBA_STATE.selectedDate);
    });
  });
}

