// __cap_freshness_check__
console.assert(
  NBA_CONTRACTS_DATA.LEAGUE_CAP.cap  === 154647000 &&
  NBA_CONTRACTS_DATA.LEAGUE_CAP.lt   === 187895000 &&
  NBA_CONTRACTS_DATA.LEAGUE_CAP.apr1 === 195945000 &&
  NBA_CONTRACTS_DATA.LEAGUE_CAP.apr2 === 207824000,
  "NBA cap figures are out of date for current season — refresh from https://www.nba.com/news/nba-salary-cap-set-2025-26"
);

function formatSalary(n){
  if(n>=1000000)return'$'+(n/1000000).toFixed(1)+'M';
  return'$'+n.toLocaleString();
}

function renderCapBanner(){
  const cap=document.getElementById('capBanner');
  if(!cap)return;
  const d=NBA_CONTRACTS_DATA;
  cap.innerHTML='<div class="cap-stat"><div class="cap-stat-label">Salary Cap</div><div class="cap-stat-value gold">'+formatSalary(d.salaryCap)+'</div></div>'+
    '<div class="cap-stat"><div class="cap-stat-label">Luxury Tax</div><div class="cap-stat-value orange">'+formatSalary(d.luxuryTax)+'</div></div>'+
    '<div class="cap-stat"><div class="cap-stat-label">1st Apron</div><div class="cap-stat-value green">'+formatSalary(d.apron1)+'</div></div>'+
    '<div class="cap-stat"><div class="cap-stat-label">2nd Apron</div><div class="cap-stat-value">'+formatSalary(d.apron2)+'</div></div>';
}

function renderSalaries(){
  const cont=document.getElementById('contractsContent');
  if(!cont)return;
  const sal=NBA_CONTRACTS_DATA.salaries;
  let html='<div class="sc-toolbar"><div class="sc-search"><i class="fas fa-search"></i><input type="text" id="salSearch" placeholder="Search player..."></div>'+
    '<div class="sc-filter-tabs" id="salTypeFilter"><span class="sc-filter-tab active" data-ft="all">All</span><span class="sc-filter-tab" data-ft="Supermax">Supermax</span><span class="sc-filter-tab" data-ft="Max">Max</span><span class="sc-filter-tab" data-ft="Rookie">Rookie</span><span class="sc-filter-tab" data-ft="Standard">Standard</span><span class="sc-filter-tab" data-ft="Vet">Vet</span></div></div>'+
    '<div class="table-wrap"><table class="sc-table"><thead><tr><th class="num">#</th><th>Player</th><th>Pos</th><th>Team</th><th class="num">Salary</th><th class="num">Years</th><th>Type</th><th>Exp</th><th>Option</th></tr></thead><tbody id="salTbody"></tbody></table></div>';
  cont.innerHTML=html;
  document.getElementById('salTbody').innerHTML=buildSalRows(sal);
  document.getElementById('salSearch').addEventListener('input',function(){filterSalTable()});
  document.querySelectorAll('#salTypeFilter .sc-filter-tab').forEach(el=>{
    el.addEventListener('click',function(){
      document.querySelectorAll('#salTypeFilter .sc-filter-tab').forEach(e=>e.classList.remove('active'));
      this.classList.add('active');
      filterSalTable();
    });
  });
}

function buildSalRows(arr){
  return arr.map((p,i)=>{
    const salCls=p.salary>=40000000?'sal-max':p.salary>=20000000?'sal-high':p.salary>=10000000?'sal-mid':'sal-low';
    const ctCls='ct-'+p.type.toLowerCase().replace(/[^a-z]/g,'');
    return '<tr><td class="num">'+(i+1)+'</td><td><div class="p-cell"><div class="p-avatar">'+p.name.split(' ').map(n=>n[0]).join('')+'</div><div><div class="p-name">'+p.name+'</div></div></div></td>'+
      '<td><span class="p-pos">'+p.pos+'</span></td><td><div class="tl-cell">'+teamLogoHTML(p.team,18)+p.team+'</div></td>'+
      '<td class="num"><span class="sal '+salCls+'">'+formatSalary(p.salary)+'</span></td>'+
      '<td class="num">'+p.years+'</td><td><span class="ct '+ctCls+'">'+p.type+'</span></td>'+
      '<td class="num">'+p.exp+'</td><td>'+(p.opt?'<span class="opt opt-'+p.opt.toLowerCase()+'">'+p.opt+'</span>':'—')+'</td></tr>';
  }).join('');
}

function filterSalTable(){
  const q=document.getElementById('salSearch').value.toLowerCase();
  const activeType=document.querySelector('#salTypeFilter .sc-filter-tab.active');
  const typeFilter=activeType?activeType.dataset.ft:'all';
  let filtered=NBA_CONTRACTS_DATA.salaries.filter(p=>{
    if(typeFilter!=='all'&&p.type!==typeFilter)return false;
    if(q&&!p.name.toLowerCase().includes(q))return false;
    return true;
  });
  document.getElementById('salTbody').innerHTML=buildSalRows(filtered);
}

function renderTeamCap(){
  const cont=document.getElementById('contractsContent');
  if(!cont)return;
  const d=NBA_CONTRACTS_DATA;
  let html='<div class="sc-toolbar"><div class="sc-search"><i class="fas fa-search"></i><input type="text" id="teamCapSearch" placeholder="Search team..."></div></div>'+
    '<div class="team-cap-grid" id="teamCapGrid"></div>';
  cont.innerHTML=html;
  renderTeamCapCards(d.teams);
  document.getElementById('teamCapSearch').addEventListener('input',function(){
    const q=this.value.toLowerCase();
    renderTeamCapCards(d.teams.filter(t=>t.name.toLowerCase().includes(q)||t.abbr.toLowerCase().includes(q)));
  });
}

function renderTeamCapCards(teams){
  const grid=document.getElementById('teamCapGrid');
  if(!grid)return;
  const C=NBA_CONTRACTS_DATA.LEAGUE_CAP;
  grid.innerHTML=teams.map(t=>{
    const overApron=t.committed>C.apr2;
    const overTax  =t.committed>C.lt;
    const overCap  =t.committed>C.cap;
    const pct=Math.min((t.committed/C.apr2)*100,100);
    const fillColor=overApron?'#b80e28':overTax?'#e67800':overCap?'#c8a000':'#005a30';
    const spaceLabel=t.overUnder>=0
      ? ('<span class="tcc-val over">-' + formatSalary(t.overUnder) + '</span>')
      : ('<span class="tcc-val under">'  + formatSalary(t.space)     + '</span>');
    return '<div class="team-cap-card"><div class="tcc-header">'+
      teamLogoHTML(t.abbr,32)+'<div><div class="tcc-name">'+t.name+'</div><div class="tcc-conf">'+t.conf+'</div></div></div>'+
      '<div class="tcc-row"><span class="tcc-label">Committed</span><span class="tcc-val '+(overApron?'over':overTax?'warning':overCap?'warning':'')+'">'+formatSalary(t.committed)+'</span></div>'+
      '<div class="tcc-row"><span class="tcc-label">'+(t.overUnder>=0?'Over Cap':'Cap Space')+'</span>'+spaceLabel+'</div>'+
      '<div class="tcc-bar-wrap"><div class="tcc-bar-label"><span>Cap Used</span><span>'+Math.round(pct)+'%</span></div>'+
      '<div class="tcc-bar-track"><div class="tcc-bar-fill" style="width:'+pct+'%;background:'+fillColor+'"></div></div></div></div>';
  }).join('');
}

function renderFreeAgents(){
  const cont=document.getElementById('contractsContent');
  if(!cont)return;
  const d=NBA_CONTRACTS_DATA;
  let html='<div class="sc-toolbar"><div class="sc-search"><i class="fas fa-search"></i><input type="text" id="faSearch" placeholder="Search free agent..."></div>'+
    '<select id="faPosFilter" class="sc-select"><option value="all">All Positions</option><option value="PG">PG</option><option value="SG">SG</option><option value="SF">SF</option><option value="PF">PF</option><option value="C">C</option></select>'+
    '<select id="faExpFilter" class="sc-select"><option value="all">All Exp.</option><option value="2025">2025</option><option value="2026">2026</option></select></div>'+
    '<div class="table-wrap"><table class="sc-table"><thead><tr><th class="num">#</th><th>Player</th><th>Pos</th><th>Age</th><th>Team</th><th>Type</th><th class="num">Value</th><th class="num">Exp</th></tr></thead><tbody id="faTbody"></tbody></table></div>';
  cont.innerHTML=html;
  document.getElementById('faTbody').innerHTML=buildFARows(d.freeAgents);
  document.getElementById('faSearch').addEventListener('input',function(){filterFATable()});
  document.getElementById('faPosFilter').addEventListener('change',function(){filterFATable()});
  document.getElementById('faExpFilter').addEventListener('change',function(){filterFATable()});
}

function buildFARows(arr){
  return arr.map((p,i)=>{
    const faTypeCls=p.type==='Unrestricted'?'ct-vet':p.type==='RFA'?'ct-ro':'';
    return '<tr><td class="num">'+(i+1)+'</td><td><div class="p-cell"><div class="p-avatar">'+p.name.split(' ').map(n=>n[0]).join('')+'</div><div><div class="p-name">'+p.name+'</div></div></div></td>'+
      '<td><span class="p-pos">'+p.pos+'</span></td><td class="num">'+p.age+'</td><td><div class="tl-cell">'+teamLogoHTML(p.team,18)+p.team+'</div></td>'+
      '<td><span class="ct '+faTypeCls+'">'+p.type+'</span></td><td class="num sal sal-high">'+p.val+'</td><td class="num">'+p.exp+'</td></tr>';
  }).join('');
}

function filterFATable(){
  const q=document.getElementById('faSearch').value.toLowerCase();
  const pos=document.getElementById('faPosFilter').value;
  const exp=document.getElementById('faExpFilter').value;
  let filtered=NBA_CONTRACTS_DATA.freeAgents.filter(p=>{
    if(pos!=='all'&&p.pos!==pos)return false;
    if(exp!=='all'&&String(p.exp)!==exp)return false;
    if(q&&!p.name.toLowerCase().includes(q))return false;
    return true;
  });
  document.getElementById('faTbody').innerHTML=buildFARows(filtered);
}

function initContracts(){
  renderCapBanner();
  renderSalaries();
  document.querySelectorAll('[data-contracts-tab]').forEach(el=>{
    el.addEventListener('click',function(){
      document.querySelectorAll('[data-contracts-tab]').forEach(e=>e.classList.remove('active'));
      this.classList.add('active');
      const tab=this.dataset.contractsTab;
      NBA_STATE.contractsTab=tab;
      if(tab==='salaries')renderSalaries();
      else if(tab==='team')renderTeamCap();
      else if(tab==='freeagents')renderFreeAgents();
    });
  });
}

