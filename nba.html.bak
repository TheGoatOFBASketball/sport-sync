function teamEraLogo(abbr,year){
  if(!year)return null;
  const y=parseInt(year);
  if(abbr==='WAS')return y<=1997?null:'1998_WAS';
  if(abbr==='NOP')return y<=2013?'2003_NOP':'2014_NOP';
  if(abbr==='CHA')return y<=2002?'1989_CHA':y<=2014?null:'2015_CHA';
  if(abbr==='DEN')return y<=2004?'1976_DEN':y<=2017?'2005_DEN':'2018_DEN';
  if(abbr==='DET')return y<=1995?null:y<=2004?'1997_DET':'2005_DET';
  if(abbr==='GSW'){
    if(y<=1990)return'1971_GSW';
    if(y<=2009)return'1991_GSW';
    return'2010_GSW';
  }
  if(abbr==='ATL')return y<=2003?'2004_ATL':y<=2014?'2007_ATL':'2015_ATL';
  if(abbr==='SAS')return y<=2016?null:'2017_SAS';
  if(abbr==='SAC')return y<=1993?null:y<=2002?'1994_SAC':y<=2015?'2003_SAC':'2016_SAC';
  if(abbr==='MIL')return y<=1988?null:y<=2005?'1989_MIL':y<=2014?'2006_MIL':'2015_MIL';
  if(abbr==='PHX')return y<=1992?null:y<=2000?'1993_PHX':'2001_PHX';
  if(abbr==='TOR')return y<=2003?null:y<=2007?'2004_TOR':y<=2014?'2008_TOR':'2015_TOR';
  if(abbr==='UTA')return y<=1995?null:y<=2004?'1996_UTA':y<=2015?'2005_UTA':'2016_UTA';
  if(abbr==='ORL')return y<=2000?'1989_ORL':y<=2009?'2001_ORL':'2010_ORL';
  if(abbr==='MIA')return y<=1999?'1988_MIA':y<=2011?'2000_MIA':'2012_MIA';
  if(abbr==='IND')return y<=1993?null:y<=2004?'1994_IND':'2005_IND';
  if(abbr==='CLE')return y<=1982?null:y<=1993?'1983_CLE':y<=2002?'1994_CLE':y<=2016?'2003_CLE':'2017_CLE';
  if(abbr==='POR')return y<=1991?'1977_POR':y<=2003?'1992_POR':'2004_POR';
  if(abbr==='LAL')return y<=1998?null:'1999_LAL';
  return null;
}
function teamAbbr(name){
  return TEAM_ABBR[name]||name.replace(/[^A-Z]/g,'').slice(0,3).toUpperCase();
}

function teamLogoOrName(name,size){
  const abbr=teamAbbr(name);
  const logo=teamLogoHTML(abbr,size);
  if(logo!==abbr)return logo;
  return '<strong>'+name+'</strong>';
}

function streakLabel(t,i,teams){
  const diff=parseFloat(t.diff);
  if(isNaN(diff))return'—';
  const prev=teams[i-1];
  if(prev){
    const prevDiff=parseFloat(prev.diff);
    if(!isNaN(prevDiff)){
      if(prevDiff>diff)return'L1';
    }
  }
  const next=teams[i+1];
  if(next){
    const nextDiff=parseFloat(next.diff);
    if(!isNaN(nextDiff)){
      if(nextDiff<diff)return'W1';
    }
  }
  return diff>0?'W2':diff<0?'L2':'—';
}

async function renderStandingsSidebar(year){
  const confs=['east','west'];
  if(!year){
    const yearSelect=document.getElementById('standingsYear');
    year=yearSelect?yearSelect.value:null;
  }
  if(!year){
    const today=new Date();
    year=String(today.getFullYear()+(today.getMonth()<8?0:1));
  }
  const allData=getStandingsData(year);
  confs.forEach(conf=>{
    const container=document.getElementById(conf==='east'?'standingsSidebar':'standingsSidebarWest');
    if(!container)return;
    const key=conf==='east'?'e':'w';
    const teams=allData&&allData[key]?allData[key].slice(0,8):null;
    if(!teams){container.innerHTML='<div class="standings-loading">No data</div>';return}
    let html='<div class="standings-table">';
    html+='<div class="standings-header"><span></span><span>Team</span><span class="stat-cell">W</span><span class="stat-cell">L</span><span class="stat-cell">GB</span><span class="stat-cell">STRK</span></div>';
    teams.forEach((t,i)=>{
      const rankCls=i<3?' top3':i<6?' p6':'';
      const abbr=t.abbr||teamAbbr(t.team);
      const logo=teamLogoHTML(abbr,22,year);
      const strk=streakLabel(t,i,teams);
      const strkCls=strk.startsWith('W')?'strk-w':strk.startsWith('L')?'strk-l':'';
      html+='<div class="standings-row"><span class="rank'+rankCls+'">'+(i+1)+'</span><span class="team-cell"><span class="team-logo-sm">'+logo+'</span><strong>'+t.team+'</strong></span><span class="stat-cell w">'+t.wins+'</span><span class="stat-cell">'+t.losses+'</span><span class="stat-cell">'+(t.gb==='—'?'—':t.gb)+'</span><span class="stat-cell '+strkCls+'">'+strk+'</span></div>';
    });
    html+='</div>';
    container.innerHTML=html;
  });
}

function playoffBadge(rank,total){
  if(total<=5)return'';
  if(rank===1)return'<span class="playoff-badge z">z</span>';
  if(rank<=3)return'<span class="playoff-badge y">y</span>';
  if(rank<=6)return'<span class="playoff-badge x">x</span>';
  if(rank<=10)return'<span class="playoff-badge pb">pb</span>';
  return'<span class="playoff-badge e">e</span>';
}

function renderOneConference(teams,containerId,year){
  const container=document.getElementById(containerId);
  if(!container)return;
  if(!teams||!teams.length){container.innerHTML='<div class="standings-loading">No data</div>';return}
  const total=teams.length;
  let html='<table class="espn-standings-table"><thead><tr><th>#</th><th>Team</th><th>W</th><th>L</th><th>PCT</th><th>GB</th><th>PPG</th><th>OPP</th><th>DIFF</th><th>STRK</th><th>L10</th></tr></thead><tbody>';
  teams.forEach((t,i)=>{
    const rank=i+1;
    const abbr=t.abbr||teamAbbr(t.team);
    const logo=teamLogoHTML(abbr,20,year);
    const pct=parseFloat(t.pct);
    const pctSty=!isNaN(pct)&&pct>=.500?'pct-pos':'pct-neg';
    const diff=parseFloat(t.diff);
    const diffCls=!isNaN(diff)&&diff>=0?'diff-pos':'diff-neg';
    const diffStr=(!isNaN(diff)&&diff>0?'+':'')+t.diff;
    const strk=streakLabel(t,i,teams);
    const strkCls=strk.startsWith('W')?'strk-w':strk.startsWith('L')?'strk-l':'';
    const badge=playoffBadge(rank,total);
    const gbVal=t.gb==='—'?'—':t.gb;
    const l10='—';
    html+='<tr><td>'+(rank)+'</td><td><div class="team-cell-s">'+badge+' '+logo+'<div><span class="team-abbr">'+abbr+'</span><span class="team-full">'+t.team+'</span></div></div></td>'+
      '<td><span class="stat-val w">'+t.wins+'</span></td>'+
      '<td><span class="stat-val l">'+t.losses+'</span></td>'+
      '<td><span class="stat-val '+pctSty+'">'+t.pct+'</span></td>'+
      '<td><span class="stat-val">'+gbVal+'</span></td>'+
      '<td><span class="stat-val ppg">'+t.ppg+'</span></td>'+
      '<td><span class="stat-val">'+t.opp+'</span></td>'+
      '<td><span class="stat-val '+diffCls+'">'+diffStr+'</span></td>'+
      '<td><span class="'+strkCls+'">'+strk+'</span></td>'+
      '<td><span class="stat-val">'+l10+'</span></td></tr>';
  });
  html+='</tbody></table>';
  container.innerHTML=html;
}

async function renderStandingsFull(){
  const yearSelect=document.getElementById('standingsYear');
  const year=yearSelect?yearSelect.value:null;
  const cyear=year||String(new Date().getFullYear());
  const data=getStandingsData(cyear);
  if(!data||(!data.e&&!data.w)){
    ['standingsEastContainer','standingsWestContainer'].forEach(id=>{const el=document.getElementById(id);if(el)el.innerHTML='<div class="standings-loading">No data for '+cyear+'</div>'});
    return;
  }
  renderOneConference(data.e||[],'standingsEastContainer',cyear);
  renderOneConference(data.w||[],'standingsWestContainer',cyear);
  renderStandingsSidebar(cyear);
  const bar=document.getElementById('seasonHighlightsBar');
  if(bar){
    const hl=SEASON_HIGHLIGHTS[cyear];
    if(hl){
      let parts=[];
      const champAbbr=teamAbbr(hl.champion);
      const champLogo=teamLogoHTML(champAbbr,24,cyear);
      parts.push('<div style="display:flex;align-items:center;gap:6px;background:linear-gradient(135deg,var(--nb-card2),var(--nb-card));border:1px solid var(--nb-border);border-radius:6px;padding:6px 12px;font-size:11px"><i class="fas fa-trophy" style="color:#ffd700"></i> <strong>Champion:</strong> '+champLogo+' '+hl.champion+'</div>');
      if(hl.mvp){
        parts.push('<div style="display:flex;align-items:center;gap:6px;background:linear-gradient(135deg,var(--nb-card2),var(--nb-card));border:1px solid var(--nb-border);border-radius:6px;padding:6px 12px;font-size:11px"><i class="fas fa-star" style="color:#ff6b00"></i> <strong>MVP:</strong> '+hl.mvp+'</div>');
      }
      if(hl.fmvp){
        parts.push('<div style="display:flex;align-items:center;gap:6px;background:linear-gradient(135deg,var(--nb-card2),var(--nb-card));border:1px solid var(--nb-border);border-radius:6px;padding:6px 12px;font-size:11px"><i class="fas fa-medal" style="color:#ffd700"></i> <strong>Finals MVP:</strong> '+hl.fmvp+'</div>');
      }
      bar.innerHTML=parts.join('');
    }else{
      bar.innerHTML='';
    }
  }
}

function initStandings(){
  const yearSelect=document.getElementById('standingsYear');
  if(!yearSelect)return;
  const bbref=window.BBREF_STANDINGS;
  if(!bbref)return;
  const years=Object.keys(bbref).map(Number).sort((a,b)=>b-a);
  yearSelect.innerHTML=years.map(y=>'<option value="'+y+'">'+(y-1)+'-'+String(y).slice(2)+'</option>').join('');
  const decadeBar=document.getElementById('standingsDecadeBar');
  if(decadeBar){
    const decades=[];
    years.forEach(y=>{
      const d=Math.floor(y/10)*10;
      if(!decades.includes(d))decades.push(d);
    });
    decades.sort((a,b)=>b-a);
    const today=new Date();
    const currentDecade=Math.floor((today.getFullYear()+(today.getMonth()<8?0:1))/10)*10;
    decadeBar.innerHTML=decades.map(d=>'<span class="standings-decade-btn'+(d===currentDecade?' active':'')+'" data-decade="'+d+'">'+d+'s</span>').join('');
    decadeBar.querySelectorAll('.standings-decade-btn').forEach(btn=>{
      btn.addEventListener('click',function(){
        decadeBar.querySelectorAll('.standings-decade-btn').forEach(b=>b.classList.remove('active'));
        this.classList.add('active');
        const dec=parseInt(this.dataset.decade);
        const opts=yearSelect.options;
        for(let i=0;i<opts.length;i++){
          const y=parseInt(opts[i].value);
          if(y>=dec&&y<dec+10){
            yearSelect.value=opts[i].value;
            renderStandingsFull();
            return;
          }
        }
      });
    });
  }
  yearSelect.addEventListener('change',()=>{
    const y=parseInt(yearSelect.value);
    const d=Math.floor(y/10)*10;
    if(decadeBar){
      decadeBar.querySelectorAll('.standings-decade-btn').forEach(b=>{
        b.classList.toggle('active',parseInt(b.dataset.decade)===d);
      });
    }
    renderStandingsFull();
  });
  renderStandingsFull();
}

/* ===== PLAYERS ===== */
function renderPlayers(){
  const grid=document.getElementById('playersGrid');
  if(!grid)return;
  const yearSelect=document.getElementById('playersYear');
  const catSelect=document.getElementById('playersCat');
  if(!yearSelect||!catSelect)return;
  const year=yearSelect.value;
  const cat=catSelect.value;
  const data=window.PLAYERS_DATA;
  if(!data||!data[year]||!data[year][cat]||!data[year][cat].length){
    grid.innerHTML='<div class="scoreboard-empty"><i class="fas fa-users"></i> No player data for '+year+'</div>';
    return;
  }
  const players=data[year][cat].slice(0,50);
  grid.innerHTML=players.map(p=>{
    const statLabel=cat==='ppg'?'PTS':cat==='apg'?'AST':'REB';
    return '<div class="player-card"><div class="player-avatar">'+(p.name.split(' ').map(n=>n[0]).join(''))+'</div>'+
      '<div class="player-name">'+p.name+'</div>'+
      '<div class="player-meta">'+teamLogoHTML(p.team,16)+' '+(p.pos||'')+' | '+p.team+'</div>'+
      '<div class="player-stat-label">'+statLabel+'</div>'+
      '<div class="player-stat">'+p.stat+'</div>'+
      '<div class="player-stats-row">'+
      '<span><strong>'+p.gp+'</strong>GP</span>'+
      (p.fg_pct?'<span><strong>'+p.fg_pct+'</strong>FG%</span>':'')+
      (p.ft_pct?'<span><strong>'+p.ft_pct+'</strong>FT%</span>':'')+
      '</div></div>';
  }).join('');
}

function initPlayers(){
  const yearSelect=document.getElementById('playersYear');
  const catSelect=document.getElementById('playersCat');
  if(!yearSelect||!catSelect)return;
  const data=window.PLAYERS_DATA;
  if(!data)return;
  const years=Object.keys(data).sort((a,b)=>parseInt(b)-parseInt(a));
  yearSelect.innerHTML=years.map(y=>'<option value="'+y+'">'+y+'</option>').join('');
  yearSelect.addEventListener('change',renderPlayers);
  catSelect.addEventListener('change',renderPlayers);
  renderPlayers();
}

/* ===== NEWS ===== */
async function loadNews(){
  const list=document.getElementById('newsList');
  if(!list)return;
  list.innerHTML='<div class="scoreboard-empty"><i class="fas fa-newspaper"></i> Loading news...</div>';
  try{
    const api=window.SPORTSYNC_API;
    let data=null;
    if(api&&api.ESPN){
      data=await api.ESPN.getNews('nba',15);
    }else{
      data=await fetchJSON('https://site.api.espn.com/apis/site/v2/sports/basketball/nba/news?limit=15');
    }
    if(data&&data.articles&&data.articles.length){
      const articles=api&&api.ESPN&&api.ESPN.parse?api.ESPN.parse.news(data):data.articles;
      list.innerHTML=articles.map(a=>renderNewsItem(a)).join('');
    }else{
      list.innerHTML='<div class="scoreboard-empty"><i class="fas fa-newspaper"></i> No news available</div>';
    }
  }catch(e){
    list.innerHTML='<div class="scoreboard-empty"><i class="fas fa-exclamation-triangle"></i> Error loading news</div>';
  }
}

function renderNewsItem(a){
  const img=a.image||a.images?.[0]?.url||'';
  const imgHtml=img?'<img src="'+img+'" alt="" style="width:100%;height:100%;object-fit:cover">':'<i class="fas fa-newspaper"></i>';
  const tag=a.tags?.[0]||(a.categories?.[0]?.description||'NBA');
  const date=a.published?new Date(a.published).toLocaleDateString('en',{month:'short',day:'numeric',year:'numeric'}):'';
  return '<div class="news-item" onclick="window.open(\''+(a.links?.web?.href||a.link||'#')+'\',\'_blank\')">'+
    '<div class="news-img">'+imgHtml+'</div>'+
    '<div class="news-content"><div class="news-tag">'+tag+'</div>'+
    '<div class="news-title">'+(a.headline||a.title||'')+'</div>'+
    '<div class="news-meta">'+(a.author?'By '+a.author+(date?' &middot; ':'') :'')+date+'</div></div></div>';
}

/* ===== CONTRACTS DATA ===== */
